// ══════════════════════════════════════════════════
window.addEventListener('resize', ()=>{ resizeCanvas(); clampCam(); draw(); });
resizeCanvas();
initState();
// Center camera roughly on player start
camX = -( 5*TILE - canvas.width/2 );
camY = -( 20*TILE - canvas.height/2 );
clampCam();
updateUI();
updateSidePanel();
addLog('🎮 Гра розпочата! Захопіть ворожі бази!','good');
draw();

// Gameloop for subtle animation
setInterval(draw, 100);
</script>
